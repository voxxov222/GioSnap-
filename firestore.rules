rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'walletAddress', 'bio', 'createdAt']) &&
             validStringLength('displayName', 1, 50) &&
             isValidOptionalString('photoURL', 0, 1000) &&
             isValidOptionalString('walletAddress', 0, 100) &&
             isValidOptionalString('bio', 0, 500) &&
             request.resource.data.createdAt is timestamp;
    }
    
    function isValidPost() {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorPhoto', 'lat', 'lng', 'mediaUrl', 'mediaType', 'description', 'tokenId', 'likesCount', 'createdAt']) &&
             request.resource.data.authorId == request.auth.uid &&
             validStringLength('authorName', 1, 50) &&
             isValidOptionalString('authorPhoto', 0, 1000) &&
             request.resource.data.lat is number &&
             request.resource.data.lng is number &&
             validStringLength('mediaUrl', 1, 1000) &&
             request.resource.data.mediaType in ['image', 'video'] &&
             isValidOptionalString('description', 0, 1000) &&
             isValidOptionalString('tokenId', 0, 100) &&
             request.resource.data.likesCount is number &&
             request.resource.data.createdAt is timestamp;
    }
    
    function isValidMessage() {
      return hasOnlyAllowedFields(['senderId', 'senderName', 'senderPhoto', 'text', 'createdAt']) &&
             request.resource.data.senderId == request.auth.uid &&
             validStringLength('senderName', 1, 50) &&
             isValidOptionalString('senderPhoto', 0, 1000) &&
             validStringLength('text', 1, 1000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidChat() {
      return hasOnlyAllowedFields(['participants', 'participantDetails', 'lastMessage', 'updatedAt']) &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() == 2 &&
             request.auth.uid in request.resource.data.participants &&
             request.resource.data.participantDetails is map &&
             isValidOptionalString('lastMessage', 0, 1000) &&
             request.resource.data.updatedAt is timestamp;
    }
    
    function isValidDirectMessage() {
      return hasOnlyAllowedFields(['senderId', 'text', 'createdAt']) &&
             request.resource.data.senderId == request.auth.uid &&
             validStringLength('text', 1, 1000) &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated(); // Public profiles for social network
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified() && 
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }
    
    match /posts/{postId} {
      allow read: if isAuthenticated(); // Anyone logged in can see posts on the globe
      allow create: if isAuthenticated() && isValidPost() && request.resource.data.likesCount == 0;
      allow update: if isAuthenticated() && 
                    // Either owner updates description/tokenId OR someone likes the post
                    (
                      (isDocOwner() && isValidPost() && 
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.likesCount == resource.data.likesCount &&
                       request.resource.data.mediaUrl == resource.data.mediaUrl)
                      ||
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) &&
                        math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1
                      )
                    );
      allow delete: if isDocOwner();
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage();
      allow update: if false; // Messages are immutable
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt']) &&
                    isValidOptionalString('lastMessage', 0, 1000) &&
                    request.resource.data.updatedAt is timestamp;
      allow delete: if false;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && isValidDirectMessage() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if false;
      }
    }
  }
}
