{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the social network.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string", "maxLength": 50 },
        "photoURL": { "type": "string" },
        "walletAddress": { "type": "string" },
        "bio": { "type": "string", "maxLength": 500 },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A post containing an image or video minted as an NFT.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string", "maxLength": 50 },
        "authorPhoto": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "description": { "type": "string", "maxLength": 1000 },
        "tokenId": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["authorId", "authorName", "lat", "lng", "mediaUrl", "mediaType", "createdAt", "likesCount"]
    },
    "Message": {
      "title": "Message",
      "description": "A live chat message in the global channel.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string", "maxLength": 50 },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string", "maxLength": 1000 },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A 1-on-1 conversation between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantDetails": { "type": "object" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["participants", "participantDetails", "updatedAt"]
    },
    "DirectMessage": {
      "title": "DirectMessage",
      "description": "A message in a 1-on-1 chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string", "maxLength": 1000 },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores all posts (NFTs) globally."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores global chat messages."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores 1-on-1 chats."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/DirectMessage" },
      "description": "Stores messages within a chat."
    }
  }
}
